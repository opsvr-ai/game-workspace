{
  "name": "@chunlv/web",
  "version": "0.0.0",
  "private": true,
  "description": "Chunlv Esports Web Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx --max-warnings 50",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\""
  },
  "dependencies": {
    "@ant-design/charts": "^2.6.7",
    "@ant-design/icons": "^5.3.0",
    "@chunlv/shared": "workspace:*",
    "@tanstack/react-virtual": "^3.14.7",
    "antd": "^5.18.0",
    "axios": "^1.7.0",
    "dayjs": "^1.11.11",
    "idb": "^8.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0",
    "recharts": "^3.9.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  }
}
