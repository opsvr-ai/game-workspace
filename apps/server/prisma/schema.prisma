generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  username           String   @unique
  passwordHash       String
  role               String   @default("COMPANION")
  studioId           String?
  isAuthorized       Boolean  @default(false)
  secondPasswordHash String?
  displayName        String?
  avatar             String?
  createdAt          DateTime @default(now())

  studio    Studio?     @relation(fields: [studioId], references: [id])
  companion Companion?
  csOrders  Order[]     @relation("CSUser")
}

model Studio {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("DIRECT")  // DIRECT | RENTAL
  createdAt DateTime @default(now())

  users      User[]
  companions Companion[]
  orders     Order[]
  customers  Customer[]
  expenses        Expense[]
  expenseReports  ExpenseReport[]
}

model Companion {
  id             String   @id @default(uuid())
  userId         String   @unique
  studioId       String
  games          Json     @default("[]")
  status         String   @default("OFFLINE")
  billingCode    String   @unique
  revenueShare   Float    @default(0.6)
  monthlyRevenue Float    @default(0)
  deposit        Float    @default(0)
  balance        Float    @default(0)
  frozen         Float    @default(0)
  realName       String?
  idNumber       String?
  phone          String?
  idCardFront    String?
  idCardBack     String?
  reviewStatus   String   @default("PENDING")  // PENDING | APPROVED | REJECTED
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime @default(now())

  user      User            @relation(fields: [userId], references: [id])
  studio    Studio          @relation(fields: [studioId], references: [id])
  pc        CompanionPC?
  timeLogs  CompanionTimeLog[]
  orders    Order[]
  customers Customer[]
  transactions Transaction[]
  expenseReports ExpenseReport[]
  walletTransactions WalletTransaction[]
  workWechats WorkWechat[]
}

model CompanionPC {
  id              String    @id @default(uuid())
  companionId     String    @unique
  agentVersion    String    @default("0.0.0")
  lastHeartbeat   DateTime?
  currentMode     String    @default("ENTERTAINMENT")
  isThrottled     Boolean   @default(false)
  throttleLimitKB Int?
  createdAt       DateTime  @default(now())

  companion      Companion        @relation(fields: [companionId], references: [id])
  operationLogs  PCOperationLog[]
}

model CompanionTimeLog {
  id              String    @id @default(uuid())
  companionId     String
  mode            String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationSeconds Int       @default(0)

  companion Companion @relation(fields: [companionId], references: [id])
}

model Order {
  id           String   @id @default(uuid())
  type         String
  studioId     String
  csUserId     String
  companionId  String?
  customerId   String
  dispatchType String
  status       String   @default("PENDING")
  amount       Float
  gameName     String
  duration     Float?
  customFields Json?
  isOnline     Boolean  @default(true)
  createdAt       DateTime @default(now())
  grabbedAt       DateTime?
  contactStatus   String?
  screenshotUrl   String?
  scheduledAt     DateTime?
  notes           String?

  studio       Studio        @relation(fields: [studioId], references: [id])
  csUser       User          @relation("CSUser", fields: [csUserId], references: [id])
  companion    Companion?    @relation(fields: [companionId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  transactions Transaction[]
}

model Customer {
  id                  String   @id @default(uuid())
  studioId            String
  customerCode        String   @unique
  wechatId            String
  companionId         String?
  platform            String?
  platformAccount     String?
  consultDate         DateTime?
  wechatAddDate       DateTime?
  isAccountBanned     Boolean  @default(false)
  isDeletedByCustomer Boolean  @default(false)
  notes               String?
  totalSpent          Float    @default(0)
  scheduledAt         DateTime?
  status              String   @default("PENDING_DEVELOPMENT")  // ACTIVE | FOLLOW_UP | LOST | PENDING_DEVELOPMENT
  createdAt           DateTime @default(now())

  studio    Studio     @relation(fields: [studioId], references: [id])
  companion Companion? @relation(fields: [companionId], references: [id])
  orders    Order[]
  profile   CustomerProfile?
  followUps CustomerFollowUp[]
}

model Transaction {
  id              String   @id @default(uuid())
  orderId         String
  companionId     String
  amount          Float
  paymentMethod   String
  screenshotUrl   String
  status          String   @default("PENDING")
  reviewedById    String?
  paidAt          DateTime
  createdAt       DateTime @default(now())

  order     Order     @relation(fields: [orderId], references: [id])
  companion Companion @relation(fields: [companionId], references: [id])
}

model RevenueDaily {
  id               String   @id @default(uuid())
  date             DateTime
  studioId         String
  companionId      String?
  newOrderCount    Int      @default(0)
  newOrderAmount   Float    @default(0)
  renewCount       Int      @default(0)
  renewAmount      Float    @default(0)
  repurchaseCount  Int      @default(0)
  repurchaseAmount Float    @default(0)
  tipCount         Int      @default(0)
  tipAmount        Float    @default(0)

  @@unique([date, studioId, companionId])
}

model Expense {
  id          String   @id @default(uuid())
  studioId    String
  category    String
  amount      Float
  description String?
  date        DateTime @default(now())

  studio Studio @relation(fields: [studioId], references: [id])
}

model PCOperationLog {
  id         String   @id @default(uuid())
  pcId       String
  operation  String
  operatorId String
  detail     String?
  createdAt  DateTime @default(now())

  pc CompanionPC @relation(fields: [pcId], references: [id])
}

model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value Json
}

model StudioDailyStats {
  id                String   @id @default(uuid())
  date              DateTime
  studioId          String
  totalRevenue      Float    @default(0)
  orderCount        Int      @default(0)
  onlineCompanions  Int      @default(0)
  totalCompanions   Int      @default(0)
  acceptRate        Float    @default(0)
  entertainmentFee  Float    @default(0)
  createdAt         DateTime @default(now())

  @@unique([date, studioId])
}

model ExpenseReport {
  id            String    @id @default(uuid())
  companionId   String
  studioId      String
  type          String    @default("EXPENSE")  // EXPENSE | WITHDRAW
  amount        Float
  screenshotUrl String?
  description   String?
  status        String    @default("PENDING")  // PENDING | APPROVED | REJECTED
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNote    String?
  createdAt     DateTime  @default(now())

  companion     Companion @relation(fields: [companionId], references: [id])
  studio        Studio    @relation(fields: [studioId], references: [id])
}

model WalletTransaction {
  id            String   @id @default(uuid())
  companionId   String
  type          String   // DEPOSIT | WITHDRAW | FREEZE | UNFREEZE | SETTLEMENT
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  note          String?
  reviewedById  String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())

  companion Companion @relation(fields: [companionId], references: [id])
}

model CustomerProfile {
  id                    String   @id @default(uuid())
  customerId            String   @unique
  age                   Int?
  address               String?
  occupation            String?
  preferredGame         String?
  preferredMode         String?
  preferredSingleDouble String?
  preferredTime         String?
  playFrequency         String?
  pricePreference       String?
  relationshipStatus    String?
  afraidWechatCheck     Boolean  @default(false)
  likedVoice            String?
  myVoice               String?
  likesTalkative        Boolean  @default(false)
  likesSkill            Boolean  @default(false)
  likesBoth             Boolean  @default(false)
  customNotes           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
}

model CustomerFollowUp {
  id          String   @id @default(uuid())
  customerId  String
  playerId    String?
  adminId     String?
  content     String
  nextAction  String?
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

model TenantAuthorization {
  id               String   @id @default(uuid())
  studioId         String
  csUserId         String
  canViewPlayers   Boolean  @default(false)
  canViewOrders    Boolean  @default(false)
  canViewAlerts    Boolean  @default(false)
  canHandleOrders  Boolean  @default(false)
  canDispatchOrders Boolean @default(false)
  createdAt        DateTime @default(now())

  @@unique([studioId, csUserId])
}

model WorkWechat {
  id          String   @id @default(uuid())
  studioId    String
  wechatId    String   @unique
  companionId String?  @unique
  status      String   @default("AVAILABLE") // AVAILABLE | BOUND | BANNED
  createdAt   DateTime @default(now())

  companion Companion? @relation(fields: [companionId], references: [id])
}
