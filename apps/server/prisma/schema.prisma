generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  username           String   @unique
  passwordHash       String
  role               String   @default("COMPANION")
  studioId           String?
  isAuthorized       Boolean  @default(false)
  secondPasswordHash String?
  displayName        String?
  avatar             String?
  address            String?
  leaseContractUrl   String?
  realName           String?                     // 真实姓名（非陪玩角色注册时填写）
  idNumber           String?                     // 身份证号（非陪玩角色注册时填写）
  phone              String?                     // 手机号（非陪玩角色注册时填写）
  customEmojis       Json      @default("[]")
  createdAt          DateTime @default(now())

  studio    Studio?     @relation(fields: [studioId], references: [id])
  companion Companion?
  csOrders  Order[]     @relation("CSUser")

  @@index([studioId])
  @@index([role])
}

model Studio {
  id               String   @id @default(uuid())
  name             String
  type             String   @default("DIRECT")  // DIRECT | RENTAL
  splitMode        String   @default("TIERED")  // TIERED | FIXED
  address          String?                     // 工作室地址
  leaseContractUrl String?                     // 租赁合同照片URL
  createdAt        DateTime @default(now())

  users             User[]
  bridgesA          StudioBridge[]  @relation("BridgeA")
  bridgesB          StudioBridge[]  @relation("BridgeB")
  companions        Companion[]
  orders            Order[]
  customers         Customer[]
  expenses          Expense[]
  expenseReports    ExpenseReport[]
  processBlacklists ProcessBlacklist[]
  processWhitelists ProcessWhitelist[]
}

model Companion {
  id             String   @id @default(uuid())
  userId         String   @unique
  studioId       String
  games          Json     @default("[]")
  status         String   @default("OFFLINE")
  billingCode    String   @unique
  revenueShare   Float    @default(0.6)
  monthlyRevenue Float    @default(0)
  deposit        Float    @default(0)
  balance        Float    @default(0)
  frozen         Float    @default(0)
  realName       String?
  idNumber       String?
  phone          String?
  idCardFront    String?
  idCardBack     String?
  reviewStatus   String   @default("PENDING")  // PENDING | APPROVED | REJECTED
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime @default(now())

  user      User            @relation(fields: [userId], references: [id])
  studio    Studio          @relation(fields: [studioId], references: [id])
  pc        CompanionPC?
  timeLogs          CompanionTimeLog[]
  attendanceRecords CompanionAttendance[]
  orders            Order[]
  coOrders          Order[]        @relation("CoCompanion")
  customers Customer[]
  transactions Transaction[]
  expenseReports ExpenseReport[]
  walletTransactions WalletTransaction[]
  workWechats WorkWechat[]
  blacklistOverrides CompanionBlacklistOverride[]
  processReports     CompanionProcessReport[]
  processKillLogs    ProcessKillLog[]
  statusBlacklists   CompanionStatusBlacklist[]

  @@index([studioId])
  @@index([status])
}

model CompanionPC {
  id              String    @id @default(uuid())
  companionId     String    @unique
  agentVersion    String    @default("0.0.0")
  lastHeartbeat   DateTime?
  currentMode     String    @default("ENTERTAINMENT")
  isThrottled     Boolean   @default(false)
  throttleLimitKB Int?
  createdAt       DateTime  @default(now())

  companion      Companion        @relation(fields: [companionId], references: [id])
  operationLogs  PCOperationLog[]
}

model CompanionTimeLog {
  id              String    @id @default(uuid())
  companionId     String
  mode            String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationSeconds Int       @default(0)

  companion Companion @relation(fields: [companionId], references: [id])

  @@index([companionId, startedAt])
}

model CompanionAttendance {
  id           String    @id @default(uuid())
  companionId  String
  date         DateTime
  loginAt      DateTime
  logoutAt     DateTime?
  workMinutes  Int       @default(0)
  isLate       Boolean   @default(false)
  isEarlyLeave Boolean   @default(false)
  createdAt    DateTime  @default(now())
  companion    Companion @relation(fields: [companionId], references: [id])
  @@unique([companionId, date])
}

model Order {
  id           String   @id @default(uuid())
  type         String
  studioId     String
  csUserId     String
  companionId  String?
  customerId   String
  dispatchType String
  status       String   @default("PENDING")
  amount       Float
  gameName     String
  serviceType  String   @default("PLAY_WITH")
  duration     Float?
  customFields Json?
  isOnline     Boolean  @default(true)
  createdAt       DateTime @default(now())
  grabbedAt       DateTime?
  contactStatus   String?
  screenshotUrl   String?
  scheduledAt     DateTime?
  notes           String?

  coCompanionId String?

  studio       Studio        @relation(fields: [studioId], references: [id])
  csUser       User          @relation("CSUser", fields: [csUserId], references: [id])
  companion    Companion?    @relation(fields: [companionId], references: [id])
  coCompanion  Companion?    @relation("CoCompanion", fields: [coCompanionId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  transactions Transaction[]

  @@index([companionId])
  @@index([customerId])
  @@index([csUserId])
  @@index([status])
  @@index([studioId, createdAt])
  @@index([status, dispatchType])
}

model Customer {
  id                  String   @id @default(uuid())
  studioId            String
  customerCode        String   @unique
  wechatId            String
  companionId         String?
  platform            String?
  platformAccount     String?
  consultDate         DateTime?
  wechatAddDate       DateTime?
  isAccountBanned     Boolean  @default(false)
  isDeletedByCustomer Boolean  @default(false)
  notes               String?
  totalSpent          Float    @default(0)
  scheduledAt         DateTime?
  status              String   @default("PENDING_DEVELOPMENT")  // ACTIVE | FOLLOW_UP | LOST | PENDING_DEVELOPMENT
  createdAt           DateTime @default(now())

  studio    Studio     @relation(fields: [studioId], references: [id])
  companion Companion? @relation(fields: [companionId], references: [id])
  orders    Order[]
  profile   CustomerProfile?
  followUps CustomerFollowUp[]

  @@index([studioId])
  @@index([companionId])
  @@index([status])
}

model Transaction {
  id              String   @id @default(uuid())
  orderId         String
  companionId     String
  amount          Float
  paymentMethod   String
  screenshotUrl   String
  status          String   @default("PENDING")
  reviewedById    String?
  paidAt          DateTime
  createdAt       DateTime @default(now())

  order     Order     @relation(fields: [orderId], references: [id])
  companion Companion @relation(fields: [companionId], references: [id])

  @@index([companionId])
  @@index([status, createdAt])
}

model RevenueDaily {
  id               String   @id @default(uuid())
  date             DateTime
  studioId         String
  companionId      String?
  newOrderCount    Int      @default(0)
  newOrderAmount   Float    @default(0)
  renewCount       Int      @default(0)
  renewAmount      Float    @default(0)
  repurchaseCount  Int      @default(0)
  repurchaseAmount Float    @default(0)
  tipCount         Int      @default(0)
  tipAmount        Float    @default(0)

  @@unique([date, studioId, companionId])
}

model Expense {
  id          String   @id @default(uuid())
  studioId    String
  category    String
  amount      Float
  description String?
  date        DateTime @default(now())

  studio Studio @relation(fields: [studioId], references: [id])

  @@index([studioId, date])
}

model PCOperationLog {
  id         String   @id @default(uuid())
  pcId       String
  operation  String
  operatorId String
  detail     String?
  createdAt  DateTime @default(now())

  pc CompanionPC @relation(fields: [pcId], references: [id])
}

model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value Json
}

model StudioDailyStats {
  id                String   @id @default(uuid())
  date              DateTime
  studioId          String
  totalRevenue      Float    @default(0)
  orderCount        Int      @default(0)
  onlineCompanions  Int      @default(0)
  totalCompanions   Int      @default(0)
  acceptRate        Float    @default(0)
  entertainmentFee  Float    @default(0)
  createdAt         DateTime @default(now())

  @@unique([date, studioId])
}

model ExpenseReport {
  id            String    @id @default(uuid())
  companionId   String
  studioId      String
  type          String    @default("EXPENSE")  // EXPENSE | WITHDRAW
  amount        Float
  screenshotUrl String?
  description   String?
  status        String    @default("PENDING")  // PENDING | APPROVED | REJECTED
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNote    String?
  createdAt     DateTime  @default(now())

  companion     Companion @relation(fields: [companionId], references: [id])
  studio        Studio    @relation(fields: [studioId], references: [id])

  @@index([companionId])
  @@index([studioId, status])
}

model WalletTransaction {
  id            String   @id @default(uuid())
  companionId   String
  type          String   // DEPOSIT | WITHDRAW | FREEZE | UNFREEZE | SETTLEMENT
  amount        Float
  balanceBefore Float
  balanceAfter  Float
  note          String?
  reviewedById  String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())

  companion Companion @relation(fields: [companionId], references: [id])

  @@index([companionId])
  @@index([createdAt])
}

model CustomerProfile {
  id                    String   @id @default(uuid())
  customerId            String   @unique
  age                   Int?
  address               String?
  occupation            String?
  preferredGame         String?
  preferredMode         String?
  preferredSingleDouble String?
  preferredTime         String?
  playFrequency         String?
  pricePreference       String?
  relationshipStatus    String?
  afraidWechatCheck     Boolean  @default(false)
  likedVoice            String?
  myVoice               String?
  likesTalkative        Boolean  @default(false)
  likesSkill            Boolean  @default(false)
  likesBoth             Boolean  @default(false)
  customNotes           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
}

model CustomerFollowUp {
  id          String   @id @default(uuid())
  customerId  String
  playerId    String?
  adminId     String?
  content     String
  nextAction  String?
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

model TenantAuthorization {
  id               String   @id @default(uuid())
  studioId         String
  csUserId         String
  canViewPlayers   Boolean  @default(false)
  canViewOrders    Boolean  @default(false)
  canViewAlerts    Boolean  @default(false)
  canHandleOrders  Boolean  @default(false)
  canDispatchOrders Boolean @default(false)
  createdAt        DateTime @default(now())

  @@unique([studioId, csUserId])
}

model WorkWechat {
  id          String   @id @default(uuid())
  studioId    String
  wechatId    String   @unique
  companionId String?  @unique
  status      String   @default("AVAILABLE") // AVAILABLE | BOUND | BANNED
  createdAt   DateTime @default(now())

  companion Companion? @relation(fields: [companionId], references: [id])
}

// ── Blacklist Process Management ──

model ProcessBlacklist {
  id          String   @id @default(uuid())
  studioId    String
  processName String
  processPath String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studio      Studio   @relation(fields: [studioId], references: [id])

  @@unique([studioId, processName])
}

model CompanionBlacklistOverride {
  id          String    @id @default(uuid())
  companionId String
  processName String
  processPath String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  companion   Companion @relation(fields: [companionId], references: [id])

  @@unique([companionId, processName])
}

model ProcessWhitelist {
  id          String   @id @default(uuid())
  studioId    String
  processName String
  processPath String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studio      Studio   @relation(fields: [studioId], references: [id])

  @@unique([studioId, processName])
}

model CompanionProcessReport {
  id          String    @id @default(uuid())
  companionId String
  reportTime  DateTime  @default(now())
  processes   Json
  totalCount  Int
  createdAt   DateTime  @default(now())

  companion   Companion @relation(fields: [companionId], references: [id])

  @@index([companionId, createdAt])
}

model ProcessKillLog {
  id           String    @id @default(uuid())
  companionId  String
  processName  String
  processPath  String?
  pid          Int?
  success      Boolean
  resultText   String?
  triggeredBy  String    @default("PERIODIC")
  operatorId   String?
  createdAt    DateTime  @default(now())

  companion    Companion @relation(fields: [companionId], references: [id])

  @@index([companionId, createdAt])
}

// ── @deprecated Legacy Chat (V1) — migrate to Chat 3.0, then drop ──
model ChatMessageLegacy {
  id         String   @id @default(uuid())
  studioId   String
  orderId    String?
  senderId   String
  senderRole String
  text       String
  createdAt  DateTime @default(now())

  @@index([studioId, orderId, createdAt])
  @@map("ChatMessage")
}

// ── @deprecated Chat V2 — migrate to Chat 3.0, then drop ──
model Conversation {
  id             String    @id @default(uuid())
  studioId       String
  participantA   String
  participantB   String
  aReadAt        DateTime?
  bReadAt        DateTime?
  lastMessage    String?
  lastMessageAt  DateTime?
  orderInfo      String?
  createdAt      DateTime  @default(now())

  messages       ChatMessage[]

  @@unique([studioId, participantA, participantB])
  @@index([studioId, participantA])
  @@index([studioId, participantB])
}

// ── @deprecated Chat V2 message — migrate to ChatMessageV3, then drop ──
model ChatMessage {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  text           String
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ChatMessageV2")
}

// ── Chat 3.0 Models ──

model ChatRoom {
  id             String    @id @default(uuid())
  studioId       String?   // null = cross-studio room between bridged studios
  participantA   String              // sorted alphabetically (smaller first)
  participantB   String
  aReadSeq       Int       @default(0)  // participantA's last-read message seq
  bReadSeq       Int       @default(0)  // participantB's last-read message seq
  lastMessage    String?              // preview text, truncated to 100 chars
  lastMessageAt  DateTime?
  lastMessageSeq Int       @default(0)  // auto-incrementing per room
  orderInfo      String?              // order summary (gameName · ¥amount · duration)
  pinned         Boolean   @default(false)
  pinnedAt       DateTime?
  archived       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  messages       ChatMessageV3[]

  @@index([studioId, participantA])
  @@index([studioId, participantB])
  @@index([studioId, pinned, lastMessageAt])
  @@index([participantA, participantB])
}

model ChatMessageV3 {
  id          String    @id @default(uuid())
  roomId      String
  room        ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId    String
  type        String    @default("TEXT")   // TEXT | IMAGE | FILE | AUDIO | ORDER_CARD | SYSTEM
  content     String?
  seq         Int                          // per-room incrementing sequence number
  replyToId   String?                      // quoted reply message ID
  replyTo     ChatMessageV3? @relation("Reply", fields: [replyToId], references: [id])
  deletedAt   DateTime?                    // soft-delete = recall
  createdAt   DateTime  @default(now())

  attachments  MessageAttachment[]
  reactions    MessageReaction[]
  repliedBy    ChatMessageV3[] @relation("Reply")

  @@unique([roomId, seq])
  @@index([roomId, createdAt])
  @@index([senderId])
  @@map("ChatMessageV3")
}

model MessageAttachment {
  id           String   @id @default(uuid())
  messageId    String
  message      ChatMessageV3 @relation(fields: [messageId], references: [id], onDelete: Cascade)
  type         String              // IMAGE | FILE | AUDIO
  url          String
  thumbnailUrl String?
  fileName     String?
  fileSize     Int?
  mimeType     String?
  width        Int?
  height       Int?
  duration     Int?                // audio seconds
  createdAt    DateTime @default(now())
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  message   ChatMessageV3 @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model ChatAuditLog {
  id        String   @id @default(uuid())
  roomId    String
  userId    String
  action    String              // SEND | RECALL | DELETE | REACT | READ
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
  @@index([userId])
}

model StudioBridge {
  id         String   @id @default(uuid())
  studioAId  String
  studioBId  String
  status     String   @default("PENDING") // PENDING | ACTIVE | REJECTED
  proposedBy String
  createdAt  DateTime @default(now())
  acceptedAt DateTime?

  studioA    Studio @relation("BridgeA", fields: [studioAId], references: [id], onDelete: Cascade)
  studioB    Studio @relation("BridgeB", fields: [studioBId], references: [id], onDelete: Cascade)
  permissions StudioBridgePermission[]

  @@unique([studioAId, studioBId])
}

model StudioBridgePermission {
  id        String @id @default(uuid())
  bridgeId  String
  function  String // ORDERS | POOL | CUSTOMERS | BILLING | KPI
  acceptedA Boolean @default(false)
  acceptedB Boolean @default(false)

  bridge    StudioBridge @relation(fields: [bridgeId], references: [id], onDelete: Cascade)

  @@unique([bridgeId, function])
}

model CompanionStatusBlacklist {
  id          String   @id @default(uuid())
  companionId String
  status      String   // AVAILABLE | WAITING | BUSY | ENTERTAINMENT | RESTING
  processName String
  createdAt   DateTime @default(now())

  companion   Companion @relation(fields: [companionId], references: [id])
  @@unique([companionId, status, processName])
  @@index([companionId, status])
}
